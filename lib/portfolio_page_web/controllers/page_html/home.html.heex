  <section id="case-studies" class="min-h-screen bg-base-100 py-16">
    <div class="container mx-auto px-4">
      <div class="text-center flex flex-col gap-4 mb-12">
        <h2 class="inline mx-auto text-3xl font-bold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
          Case Studies
        </h2>
      </div>

      <div class="card lg:card-side bg-base-200 shadow-xl shadow-primary/5">
        <figure class="lg:w-2/5">
          <img
            src="/images/backgrounds/construction-background.jpg"
            alt="Construction management dashboard showing project tracking"
            class="w-full h-64 lg:h-full object-cover"
          />
        </figure>

        <div class="card-body lg:w-3/5">
          <div class="flex flex-wrap gap-2">
            <div class="badge badge-primary badge-lg badge-secondary">
              <.icon name="hero-sparkles" class="size-4" /> Featured Project
            </div>
          </div>

          <h2 class="text-primary font-bold text-2xl mb-2">
            XProcura - Revolutionizing Construction Management
          </h2>

          <p class="text-lg text-base-content/80 leading-relaxed mb-4">
            XProcura is a construction procurement tracking software to help general
            contractors track shipments on a worksite. A sophisticated platform built
            for enterprise-scale operations.
          </p>

          <h5 class="text-secondary text-lg font-bold">Key Features:</h5>
          <ul class="flex flex-col gap-2 text-base lg:text-lg">
            <li class="flex gap-3 items-start">
              <.icon name="hero-check-circle" class="size-5 text-secondary shrink-0 mt-0.5" />
              <span>Multi-tenant multi-project application architecture</span>
            </li>
            <li class="flex gap-3 items-start">
              <.icon name="hero-check-circle" class="size-5 text-secondary shrink-0 mt-0.5" />
              <span>Complete enterprise and project admin system</span>
            </li>
            <li class="flex gap-3 items-start">
              <.icon name="hero-check-circle" class="size-5 text-secondary shrink-0 mt-0.5" />
              <span>User-driven shipment confirmations with automated warnings</span>
            </li>
            <li class="flex gap-3 items-start">
              <.icon name="hero-check-circle" class="size-5 text-secondary shrink-0 mt-0.5" />
              <span>Complex permission system with role-based access</span>
            </li>
            <li class="flex gap-3 items-start">
              <.icon name="hero-check-circle" class="size-5 text-secondary shrink-0 mt-0.5" />
              <span>Real-time tracking and notifications</span>
            </li>
            <li class="flex gap-3 items-start">
              <.icon name="hero-check-circle" class="size-5 text-secondary shrink-0 mt-0.5" />
              <span>Subcontractor visibility limited to assigned divisions</span>
            </li>
          </ul>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 my-4">
            <div class="card bg-base-100 bg-gradient-to-br from-primary/5 to-secondary/5 shadow-md">
              <div class="card-body items-center text-center gap-2">
                <.icon name="hero-users" class="size-12 text-primary" />
                <h5 class="font-bold text-2xl bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
                  Multi
                </h5>
                <p class="text-sm font-medium text-base-content/70">Tenant</p>
              </div>
            </div>

            <div class="card bg-base-100 bg-gradient-to-br from-primary/5 to-secondary/5 shadow-md">
              <div class="card-body items-center text-center gap-2">
                <.icon name="hero-shield-check" class="size-12 text-primary" />
                <h5 class="font-bold text-2xl bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
                  Advanced
                </h5>
                <p class="text-sm font-medium text-base-content/70">Authorization</p>
              </div>
            </div>

            <div class="card bg-base-100 bg-gradient-to-br from-primary/5 to-secondary/5 shadow-md">
              <div class="card-body items-center text-center gap-2">
                <.icon name="hero-signal" class="size-12 text-primary" />
                <h5 class="font-bold text-2xl bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
                  Real-time
                </h5>
                <p class="text-sm font-medium text-base-content/70">Updates</p>
              </div>
            </div>
          </div>

          <div class="card-actions">
            <.link
              navigate="/blogs/xprocura-case-study"
              class=" btn btn-primary btn-lg px-8 w-full"
            >
              Learn More
            </.link>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="bg-base-100">
    <div class="mx-auto h-1 w-64 bg-gradient-to-tr from-primary to-secondary rounded-full"></div>
  </div>

  <section
    id="blog-section"
    class="min-h-screen bg-base-100 py-16 bg-radial from-primary/20 via-base-100 to-base-100"
  >
    <div class="container mx-auto px-4">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6 mb-12">
        <div class="flex flex-col gap-3">
          <h2 class="text-3xl pb-1 font-bold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
            Blog Posts
          </h2>
          <p class="text-lg text-base-content">
            Programming Tutorials, Case Studies, and insights  
          </p>
        </div>

        <.link navigate="/blogs" class="btn btn-primary btn-lg btn-soft group">
          View All
          <.icon
            name="hero-arrow-right"
            class="size-5 transition-transform group-hover:translate-x-1"
          />
        </.link>
      </div>

      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <li :for={post <- PortfolioPage.Blog.get_recent_posts(4)}>
          <.blog_post_link post={post} />
        </li>
      </ul>
    </div>
  </section>

  <div class="bg-base-100">
    <div class="mx-auto h-1 w-64 bg-gradient-to-tr from-primary to-secondary rounded-full"></div>
  </div>

  <section id="contact-us" class="bg-base-100 py-16 relative overflow-hidden">
    <!-- Decorative background elements (subtle) -->
    <div class="absolute inset-0 bg-radial from-primary/5 via-transparent to-transparent opacity-50">
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl mx-auto">
        <!-- Header section -->
        <div class="text-center mb-4 lg:mb-8">
          <h2 class="text-3xl pb-1 font-bold inline-block bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent mb-4">
            Let's Talk about Your Project
          </h2>
        </div>
        
<!-- Contact form -->
        <div class="card bg-base-200 shadow-xl border border-base-200">
          <div id="contact-form" class="card-body gap-6 p-6 lg:p-8">
            <div class="card-title flex flex-col gap-4 sm:flex-row justify-between w-full">
              <h4 class="card-title">Contact Form</h4>
              <a href="mailto:bhammer@livelogicdev.com" class="btn btn-ghost btn-sm">
                <.icon name="hero-envelope" class="size-5" />
                <span class="text-break"> bhammer@livelogicdev.com </span>
              </a>
            </div>

            <.form
              for={@contact_form}
              action={~p"/contact"}
              as={:contact}
              method="post"
              class="space-y-6"
            >
              <div class="grid md:grid-cols-2 gap-4">
                <div class="form-control">
                  <label class="label">
                    <span class="label-text font-medium">Full Name</span>
                    <span class="label-text-alt text-error">*</span>
                  </label>
                  <input
                    type="text"
                    name="contact[name]"
                    value={@contact_form["name"]}
                    placeholder="John Doe"
                    required
                    class="input input-bordered w-full focus:input-primary transition-colors"
                  />
                </div>

                <div class="form-control">
                  <label class="label">
                    <span class="label-text font-medium">Email Address</span>
                    <span class="label-text-alt text-error">*</span>
                  </label>
                  <label class="input input-bordered flex items-center gap-2 focus-within:input-primary transition-colors">
                    <.icon name="hero-envelope" class="size-4 text-base-content/50" />
                    <input
                      type="email"
                      name="contact[email]"
                      value={@contact_form["email"]}
                      placeholder="you@company.com"
                      required
                      class="grow"
                    />
                  </label>
                </div>
              </div>

              <div class="form-control">
                <label class="label">
                  <span class="label-text font-medium">Subject (Optional)</span>
                </label>
                <input
                  type="text"
                  name="contact[subject]"
                  value={@contact_form["subject"]}
                  placeholder="What's this about?"
                  class="input input-bordered w-full focus:input-primary transition-colors"
                />
              </div>

              <div class="form-control">
                <label class="label">
                  <span class="label-text font-medium">Message</span>
                  <span class="label-text-alt text-error">*</span>
                </label>
                <textarea
                  name="contact[message]"
                  value={@contact_form["message"]}
                  rows="6"
                  placeholder="Tell us about your project, idea, or question..."
                  required
                  class="textarea textarea-bordered w-full resize-none focus:textarea-primary transition-colors"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full btn btn-primary btn-lg px-8 gap-2 order-2 sm:order-1"
              >
                Send
              </button>
            </.form>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!--
<section
  hidden
  id="unknown-section"
  class="relative h-screen w-full"
>-->
