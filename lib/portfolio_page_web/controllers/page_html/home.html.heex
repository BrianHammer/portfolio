<Layouts.app flash={@flash}>
  <section
    id="home"
    class="relative min-h-[90vh] w-full"
  >
    <!-- Background layer -->
    <div class="absolute inset-0">
      <img
        src={~p"/images/backgrounds/gold-effects-3.jpg"}
        class="h-full w-full object-cover object-center-left"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-base-100/100 via-base-100/0 to-base-100/100">
      </div>
    </div>
    
<!-- Content goes here -->
    <div class="container mx-auto h-full min-h-[90vh] flex items-center justify-center relative z-10 px-4">
      <div class="card  max-w-150 bg-base-100/0">
        <div class="card-body">
          <h2 class="card-title font-semibold text-4xl bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
            From Idea to Reliable Real-Time Software
          </h2>
          <p class="mt-4 mb-2  text-md sm:text-lg text-base-content">
            We build software built on the BEAM, a technology for scalable, fault-tolerant
            real-time systems.
          </p>
          <div class="my-1 flex flex-col md:flex-row gap-2">
            <div class="badge">Brian Hammer</div>
            <div class="badge">Full Stack Developer</div>
            <div class="badge">Elixir / Phoenix LiveView Specialist</div>
          </div>

          <div class="card-actions justify-start ">
            <.link navigate="/#contact-us" class="btn btn-primary btn-lg">Contact</.link>
            <.link navigate="/#problem-section" class="btn btn-secondary btn-outline btn-lg">
              Learn More
            </.link>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    id="about"
    class="bg-base-100 py-16 lg:py-16"
  >
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-semibold text-center mb-8">
        We
        <span class="font-bold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
          Midigate Risks
        </span>
        of Real-Time Development
      </h2>

      <div class="grid grid-cols-12 gap-4">
        <div class="col-span-12 md:col-span-7  card bg-base-200 card-lg shadow-sm ">
          <div class="card-body">
            <h2 class="card-title font-bold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
              Built on Rock-Solid Foundations
            </h2>
            <p class="text-base-content/50">
              It's common for undetected errors to cause entire servers to crash.
              BEAM was built to power telecom systems where downtime isn't an option,
              so failures stay isolated instead of bringing everything down.
            </p>
          </div>
        </div>

        <div class="col-span-12 md:col-span-5 card bg-base-200 card-lg shadow-sm">
          <div class="card-body">
            <h2 class="card-title">Scaling From the Start</h2>
            <p class="text-base-content/50">
              Real-time apps with 1,000 users can break at 10,000 and require immediate re-writes.
              BEAM was built for handling millions of concurrent users and is used by Discord and WhatsApp.
            </p>
          </div>
        </div>

        <div class="col-span-12 md:col-span-5 card bg-base-200 card-lg shadow-sm">
          <div class="card-body">
            <h2 class="card-title">Predictable Systems Save Money</h2>
            <p class="text-base-content/50">
              We use functional programming for its readability and predictability.
              Less hidden complexity means less technical debt and maintenance costs.
            </p>
          </div>
        </div>

        <div class=" col-span-12 md:col-span-7 card bg-base-200 card-lg shadow-sm">
          <div class="card-body">
            <h2 class="card-title">Real-Time First, Not an Afterthought</h2>
            <p class="text-base-content/50">
              Real-time features become fragile when added as an afterthought.
              We use tools built specifically for persistent connections and live updates,
              resulting in smoother user experiences and fewer edge-case failures.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="bg-base-100">
    <div class="mx-auto h-1 w-64 bg-gradient-to-tr from-primary to-secondary rounded-full"></div>
  </div>

  <section id="services" class="bg-base-100 py-16 lg:py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-semibold text-center mb-8">
        Our Services from
        <span class="font-bold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
          Design to Development
        </span>
      </h2>

      <div class="w-full flex flex-col lg:flex-row gap-4 mb-8">
        <.icon_card
          icon_name="hero-circle-stack"
          title="Product Development"
          subtitle="Everything from design, development, hosting, and scaling"
        />

        <.icon_card
          icon_name="hero-command-line"
          title="Full Stack Development"
          subtitle="Full Stack development with a focus on Phoenix LiveView"
        />
        <.icon_card
          icon_name="hero-computer-desktop"
          title="UX/UI Design"
          subtitle="Wireframes and Figma designs using DaisyUI components to save development time"
        />
      </div>
      
<!--
      <.icon_card_large
        icon_name="hero-chat-bubble-left-ellipsis"
        title="Let's Talk About"
        title_highlight="Your Project."
        subtitle="Reach out today and see how we can help."
      />-->

      <div class="">
        <h3 class="text-xl mb-4">
          <span class="font-bold">
            Tech Stack
          </span>
        </h3>

        <div class="flex flex-row flex-wrap gap-2">
          <div class="badge badge-primary  badge-xl">Elixir</div>
          <div class="badge badge-primary  badge-xl">Phoenix</div>

          <div class="badge badge-primary  badge-xl">LiveView</div>
          <div class="badge badge-primary badge-soft badge-xl">JavaScript</div>
          <div class="badge badge-primary badge-soft badge-xl">Tailwind</div>
          <div class="badge badge-primary badge-soft badge-xl">Daisy UI</div>
          <div class="badge badge-primary badge-soft badge-xl">Postgres</div>
          <div class="badge badge-primary badge-soft badge-xl">Ecto</div>
          <div class="badge badge-primary bg-base-100 border-base-100 badge-soft badge-xl">
            And More...
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="bg-base-100">
    <div class="mx-auto h-1 w-64 bg-gradient-to-tr from-primary to-secondary rounded-full"></div>
  </div>
  
